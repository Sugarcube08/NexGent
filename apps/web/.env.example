# --- API ---
# The public URL of your Shoujiki Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Solana Infrastructure ---
# Use the same RPC as the backend for consistency
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# The Squads V4 Program ID.
# Standard: SQDS4Byj9s7BfR7atvH9iSnduXW1U9CAdX9rW5L2S8X
NEXT_PUBLIC_SQUADS_PROGRAM_ID=SQDS4Byj9s7BfR7atvH9iSnduXW1U9CAdX9rW5L2S8X

# --- Deployment Note ---
# Ensure the API is reachable from the client-side.
# For local dev with Docker, this is usually http://localhost:8000
